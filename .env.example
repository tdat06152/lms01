NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# Server-only (required for /admin user management + bootstrap ADMIN_EMAIL)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-service-role-key>

# Fixed admin Gmail (server-only). Example: yourname@gmail.com
ADMIN_EMAIL=you@example.com

# Cloudflare R2 (server-only; do NOT expose to client)
R2_ACCOUNT_ID=<your-r2-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET=<your-bucket-name>

# Optional: public base URL if you enable a public bucket domain (recommended for images)
# Example: https://<your-bucket>.<your-subdomain>.r2.dev
R2_PUBLIC_BASE_URL=https://<your-bucket>.<your-subdomain>.r2.dev
